{
  "name": "pomodoro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/post-build.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "deploy": "gh-pages -d dist --dotfiles",
    "lp:dev": "sass --watch lp/scss/main.scss:lp/css/style.css --source-map",
    "lp:build": "sass lp/scss/main.scss:lp/css/style.css --style=compressed --no-source-map",
    "lp:deploy": "npm run lp:build && node --env-file=.env scripts/deploy-lp.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-sounds": "node scripts/generate-alarm-sounds.mjs",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "android:dev": "npm run build && npx cap sync android && TEMP=C:/tmp TMP=C:/tmp npx cap run android",
    "android:build": "npm run build && npx cap sync android",
    "android:apk": "npm run build && npx cap sync android && cd android && TEMP=C:/tmp TMP=C:/tmp ./gradlew assembleDebug --no-daemon",
    "android:release": "npm run build && npx cap sync android && cd android && TEMP=C:/tmp TMP=C:/tmp ./gradlew bundleRelease --no-daemon"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@neondatabase/neon-js": "^0.2.0-beta.1",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "gh-pages": "^6.3.0",
    "globals": "^15.14.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.1",
    "sass": "^1.97.3",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "ssh2-sftp-client": "^12.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-precaching": "^7.4.0"
  }
}
