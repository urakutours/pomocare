# pomocare-api (Cloudflare Worker) — Secret 正本 placeholder リスト
#
# このファイルは「Cloudflare Worker に登録すべき secret の placeholder 一覧」。
# 実値は commit せず、production には `wrangler secret put <KEY>` で登録する。
# Local wrangler dev で必要なら `.dev.vars` (gitignored) に実値を書く。
#
# 規律: 新規 secret 追加は本ファイル + wrangler 登録のみ。`.env.local` (repo root) には二重列挙しない。
#       詳細: workers/README.md / docs/secret-audit.md
#
# 機密度: 🔴 実機密 / 🟡 semi-public / 🟢 公開可

# === 必須 (8 keys) ===

NEON_DATABASE_URL=               # 🔴 postgres://user:pass@host/neondb (Neon Console → Connection string)
NEON_AUTH_URL=                   # 🟡 https://ep-xxx.neonauth.c-X.<region>.aws.neon.tech/neondb/auth (Worker session 検証用、VITE_NEON_AUTH_URL と同値)
STRIPE_SECRET_KEY=               # 🔴 rk_live_* (restricted key 推奨) or sk_live_* (Stripe Dashboard → Developers → API keys)
STRIPE_WEBHOOK_SECRET=           # 🔴 whsec_* (Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret)
STRIPE_PRICE_STANDARD=           # 🟢 price_* (Stripe Dashboard → Products → Standard plan)
STRIPE_PRICE_PRO=                # 🟢 price_* (Stripe Dashboard → Products → Pro plan)
RESEND_API_KEY=                  # 🔴 re_* (Resend Dashboard → API Keys)
RESEND_FROM=                     # 🟢 from address e.g. "PomoCare <noreply@pomocare.com>"

# === Optional ===

STRIPE_PORTAL_CONFIG_ID=         # 🟢 bpc_* (Custom Customer Portal configuration、未設定なら default が使われる)

# === Legacy (削除予定: 2026-06-13、wrangler.toml コメント参照) ===
# Web Push pipeline は廃止済 (tab-open delivery via Service Worker showNotification() で十分)。
# rotation 不要、削除予定日以降に wrangler secret delete <KEY> で消す。

VAPID_SUBJECT=                   # 🟢 mailto:info@pomocare.com (legacy Web Push)
VAPID_PUBLIC_KEY=                # 🟢 BN2Q... (legacy)
VAPID_PRIVATE_KEY=               # 🔴 (legacy、rotation 不要・削除日まで放置で OK)
